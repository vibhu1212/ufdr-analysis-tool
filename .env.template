# UFDR Analysis Tool Configuration
# Copy this file to .env and update with your values

# Storage Configuration
STORAGE_PROVIDER=local  # Options: local, azure, s3

# Azure Storage (if using Azure)
AZURE_CONNECTION_STRING=
AZURE_CONTAINER=ufdr-storage

# AWS S3 (if using S3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=ufdr-storage

# Model Paths (Local)
LLM_MODEL_PATH=infra/models/llm/mistral-7b-instruct-v0.2.Q4_K_M.gguf
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

# Security
ENABLE_ENCRYPTION=true
ENABLE_AUDIT_LOG=true
JWT_SECRET_KEY=your-secret-key-here

# Performance
MAX_WORKERS=4
BATCH_SIZE=100
CACHE_SIZE_MB=1024

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/ufdr_analysis.log